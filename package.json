{
  "name": "secrets-detector",
  "displayName": "Secrets Detector",
  "description": "Detects hardcoded secrets, API keys and passwords in your code",
 "version": "0.0.2",
"publisher": "MinhajIslam",
  "engines": { 
    "vscode": "^1.80.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "icon": "images/icon.png",
 "activationEvents": [
  "onCommand:secretsDetector.scanSecrets",
  "onLanguage:javascript",
  "onLanguage:typescript",
  "workspaceContains:**/*.env"
],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "secrets-detector.scan",
        "title": " Scan for Secrets"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
